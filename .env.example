# ─── Wix Headless ────────────────────────────────────────────────────────────
# Find these in: Wix Dashboard → Settings → API Keys
VITE_WIX_SITE_ID=
VITE_WIX_API_KEY=

# ─── Ably Real-Time Chat ──────────────────────────────────────────────────────
# Use the *subscribe-only* key from your Ably dashboard (not the root key)
VITE_ABLY_SUBSCRIBE_KEY=

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate a keypair: npx web-push generate-vapid-keys
# Put the PUBLIC key here; keep the PRIVATE key in Cloudflare Worker secrets
VITE_VAPID_PUBLIC_KEY=

# ─── Mux Live Stream ─────────────────────────────────────────────────────────
# Found in Mux Dashboard → Live Streams → your stream → Playback IDs
VITE_MUX_PLAYBACK_ID=

# ─── Cloudflare Worker URL ───────────────────────────────────────────────────
# Your deployed CF Worker URL (or http://localhost:8787 for local dev)
VITE_CF_WORKER_URL=http://localhost:8787

# ─── Wix OAuth (for Insiders member auth) ────────────────────────────────────
# 1. Go to Wix Dashboard → Settings → Advanced → OAuth Apps
# 2. Click "Create OAuth App"
# 3. Add allowed redirect URIs:
#      http://localhost:5173/auth/callback   (dev)
#      https://<your-domain>/auth/callback   (prod)
# 4. Copy the Client ID below
VITE_WIX_CLIENT_ID=

# ─── Wix Groups (Insiders group) ─────────────────────────────────────────────
# 1. Go to Wix Dashboard → Groups → click your Insiders group
# 2. Copy the Group ID from the URL:
#      https://manage.wix.com/.../.../groups/<GROUP_ID>/...
VITE_WIX_INSIDERS_GROUP_ID=
